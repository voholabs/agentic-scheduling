FROM node:22.20-bookworm-slim
ARG NEXT_PUBLIC_VERSION
ENV NEXT_PUBLIC_VERSION=$NEXT_PUBLIC_VERSION
RUN apt-get update && apt-get install -y --no-install-recommends \
    g++ \
    make \
    python3-pip \
    bash \
    nginx \
    curl \
    ca-certificates \
&& rm -rf /var/lib/apt/lists/*

# Temporal CLI — Postiz requires a Temporal workflow server. We run its
# built-in dev server (SQLite-backed) in-container so backend + orchestrator
# reach it at the default localhost:7233 with no cross-service networking.
ARG TEMPORAL_CLI_VERSION=1.3.0
RUN curl -sSfL "https://github.com/temporalio/cli/releases/download/v${TEMPORAL_CLI_VERSION}/temporal_cli_${TEMPORAL_CLI_VERSION}_linux_amd64.tar.gz" -o /tmp/temporal.tgz \
 && tar -xzf /tmp/temporal.tgz -C /usr/local/bin temporal \
 && rm /tmp/temporal.tgz \
 && temporal --version

RUN addgroup --system www \
 && adduser --system --ingroup www --home /www --shell /usr/sbin/nologin www \
 && mkdir -p /www \
 && chown -R www:www /www /var/lib/nginx


RUN npm --no-update-notifier --no-fund --global install pnpm@10.6.1 pm2

WORKDIR /app

COPY . /app
COPY var/docker/nginx.conf /etc/nginx/nginx.conf
RUN chmod +x /app/var/docker/start.sh

RUN pnpm install
RUN NODE_OPTIONS="--max-old-space-size=4096" pnpm run build

CMD ["sh", "/app/var/docker/start.sh"]
